# LangSight — environment variables
# Copy to .env and fill in real values.
# Never commit .env to git.

# ─── Authentication ───────────────────────────────────────────────────────────
# Comma-separated API keys for the LangSight REST API.
# Generate with: langsight api-key generate
# Leave blank to disable auth (local dev only — do NOT expose to a network).
LANGSIGHT_API_KEYS=

# Comma-separated CORS allowed origins (restrict in production).
LANGSIGHT_CORS_ORIGINS=http://localhost:3003,http://localhost:3002

# ─── Dashboard auth ───────────────────────────────────────────────────────────
# Secret for NextAuth session signing.  Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-in-production
NEXTAUTH_SECRET=change-me-in-production

# ─── Storage ──────────────────────────────────────────────────────────────────
# Override storage mode set in .langsight.yaml (sqlite | postgres | clickhouse)
# LANGSIGHT_STORAGE_MODE=clickhouse

# PostgreSQL (used for app metadata)
# LANGSIGHT_POSTGRES_URL=postgresql://langsight:langsight@localhost:5433/langsight
POSTGRES_PASSWORD=langsight

# ClickHouse (used for traces / health history)
# LANGSIGHT_CLICKHOUSE_URL=http://localhost:8123
# LANGSIGHT_CLICKHOUSE_DATABASE=langsight

# ─── Alerts ───────────────────────────────────────────────────────────────────
# LANGSIGHT_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── investigate command (LLM provider) ──────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
