# LangSight — environment variables
# Copy to .env and fill in ALL required values before running docker compose up.
# Never commit .env to git — it is in .gitignore.

# ─── REQUIRED for docker compose up ──────────────────────────────────────────

# API authentication — at least one key required when deploying.
# Generate with: langsight api-key generate
# Leave blank only for local CLI-only mode (langsight mcp-health, etc.)
LANGSIGHT_API_KEYS=

# Dashboard session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Dashboard admin login credentials
LANGSIGHT_ADMIN_EMAIL=admin@example.com
LANGSIGHT_ADMIN_PASSWORD=

# PostgreSQL password — choose a strong password
POSTGRES_PASSWORD=

# ClickHouse credentials — set a non-default user and password
CLICKHOUSE_USER=langsight
CLICKHOUSE_PASSWORD=

# ─── Security (REQUIRED for production) ──────────────────────────────────────

# Encryption at rest for provider API keys stored in Postgres.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Without this, provider API keys (Anthropic/OpenAI/Gemini) are stored plaintext.
LANGSIGHT_SECRET_KEY=

# HMAC signing of proxy auth headers (dashboard → API).
# REQUIRED — without this, session auth via proxy headers is disabled.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be set identically on API and dashboard containers.
LANGSIGHT_PROXY_SECRET=

# ─── OTEL Collector (optional — enable with: docker compose --profile otel up -d)
# Not needed for langsight.auto_patch() — the SDK sends traces directly to the API.
# Only needed if you have existing OTEL instrumentation you want to forward.
#
# OTEL_COLLECTOR_TOKEN=          # Bearer token for inbound OTLP connections
# LANGSIGHT_OTEL_COLLECTOR_KEY=  # API key for collector → API forwarding

# Separate API key for the dashboard proxy — avoids sharing the admin key.
# Falls back to LANGSIGHT_API_KEYS if not set (backwards compatible).
# LANGSIGHT_DASHBOARD_KEY=

# ─── Redis (optional — required for multi-worker) ────────────────────────────
# Generate password: openssl rand -hex 24
# Start Redis:       docker compose --profile redis up -d
# REDIS_PASSWORD=
# LANGSIGHT_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
# LANGSIGHT_WORKERS=4

# ─── Optional ─────────────────────────────────────────────────────────────────

# CORS allowed origins (restrict to your dashboard URL in production)
# LANGSIGHT_CORS_ORIGINS=https://langsight.yourdomain.com

# Dashboard public URL (used by NextAuth for redirects)
# NEXTAUTH_URL=http://localhost:3003

# Storage mode override (postgres | clickhouse | dual). Default: dual.
# LANGSIGHT_STORAGE_MODE=dual

# ClickHouse connection (if not using defaults)
# LANGSIGHT_CLICKHOUSE_URL=http://localhost:8123
# LANGSIGHT_CLICKHOUSE_DATABASE=langsight

# PostgreSQL connection (if not using docker compose default)
# LANGSIGHT_POSTGRES_URL=postgresql://langsight:<password>@localhost:5433/langsight

# ─── Performance tuning ─────────────────────────────────────────────────────
# LANGSIGHT_SSE_MAX_CLIENTS=1000        # Max SSE connections per worker (default: 1000)
# LANGSIGHT_SSE_CLIENT_BUFFER=200       # SSE buffer per client (default: 200)
# LANGSIGHT_MAX_CONCURRENT_TRACE_READS=5  # Concurrent session trace reads (default: 5)

# ─── Alerts ───────────────────────────────────────────────────────────────────
# LANGSIGHT_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── investigate command (LLM provider) ──────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
